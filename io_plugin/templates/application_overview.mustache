<div class="dhbwio-application-overview container-fluid">

    <h3>{{title}}</h3>

    {{#hasapplications}}
        <table class="table table-striped">
            <thead>
                <tr>
                    {{#isadmin}}
                        <th>{{#str}} applicant_name, dhbwio {{/str}}</th>
                        <th>{{#str}} studyprogram, dhbwio {{/str}}</th>
                        <th>{{#str}} modified, dhbwio {{/str}}</th>
                        <th>{{#str}} created, dhbwio {{/str}}</th>
                        <th>{{#str}} accepted_university, dhbwio {{/str}}</th>
                        <th>{{#str}} status, dhbwio {{/str}}</th>
                    {{/isadmin}}

                    {{^isadmin}}
                        <th>{{#str}} created, dhbwio {{/str}}</th>
                        <th>{{#str}} firstchoice, dhbwio {{/str}}</th>
                        <th>{{#str}} secondchoice, dhbwio {{/str}}</th>
                        <th>{{#str}} thirdchoice, dhbwio {{/str}}</th>
                        <th>{{#str}} accepted_university, dhbwio {{/str}}</th>
                    {{/isadmin}}

                    <th>{{#str}} action, dhbwio {{/str}}</th>
                </tr>
            </thead>

            <tbody>
                {{#applications}}
                    <tr>
                        {{#isadmin}}
                            <td>{{applicantname}}</td>
                            <td>{{studyprogram}}</td>
                            <td>{{timemodified}}</td>
                            <td>{{timecreated}}</td>
                            <td>{{acceptedchoice}}</td>
                            <td>
                                <span class="dhbwio-status-badge {{statusclass}}">
                                    {{status}}
                                </span>
                            </td>
                        {{/isadmin}}

                        {{^isadmin}}
                            <td>{{timecreated}}</td>
                            <td>{{firstchoice}}</td>
                            <td>{{secondchoice}}</td>
                            <td>{{thirdchoice}}</td>
                            <td>{{acceptedchoice}}</td>
                        {{/isadmin}}

                        <td>
                            {{{actions}}}
                        </td>
                    </tr>
                {{/applications}}
            </tbody>
        </table>
    {{/hasapplications}}

    {{^hasapplications}}
        <p>{{emptytext}}</p>
    {{/hasapplications}}

</div>