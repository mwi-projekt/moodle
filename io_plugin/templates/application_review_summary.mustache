<div class="dhbwio-application-review-summary card">

    <div class="card-header">
        <h4 class="mb-0">Bewerbungsübersicht</h4>
    </div>

    <div class="card-body">
        <table class="table table-striped">
            <tbody>
                <tr>
                    <th scope="row" style="width: 30%;">Name</th>
                    <td>{{name}}</td>
                </tr>
                <tr>
                    <th scope="row">E-Mail</th>
                    <td>{{email}}</td>
                </tr>
                <tr>
                    <th scope="row">Kurs</th>
                    <td>{{course}}</td>
                </tr>
                <tr>
                    <th scope="row">Studiengang</th>
                    <td>{{studyprogram}}</td>
                </tr>
                <tr>
                    <th scope="row">Studiengangsleitung</th>
                    <td>{{director}}</td>
                </tr>
                <tr>
                    <th scope="row">Erstwunsch</th>
                    <td>{{firstchoice}}</td>
                </tr>
                <tr>
                    <th scope="row">Zweitwunsch</th>
                    <td>{{secondchoice}}</td>
                </tr>
                <tr>
                    <th scope="row">Drittwunsch</th>
                    <td>{{thirdchoice}}</td>
                </tr>
            </tbody>
        </table>
    </div>

</div>